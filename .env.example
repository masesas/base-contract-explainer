# ===========================================
# ContractLens — Environment Variables
# ===========================================
# Copy file ini ke .env.local untuk development:
#   cp .env.example .env.local
#
# Untuk production (Vercel), set via:
#   Dashboard → Project → Settings → Environment Variables
# ===========================================

# ------------------------------------------
# AI PROVIDERS (minimal 1 wajib diisi)
# ------------------------------------------

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google (Gemini) — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# ------------------------------------------
# BLOCKCHAIN DATA (wajib)
# ------------------------------------------

# Etherscan API V2 — https://etherscan.io/myapikey
# Satu key support Base (chainid=8453) + 60+ chain lain
ETHERSCAN_API_KEY=

# BaseScan API (alternatif jika tidak pakai Etherscan V2)
# https://basescan.org/myapikey
BASESCAN_API_KEY=

# ------------------------------------------
# BASE NETWORK RPC
# ------------------------------------------

# Public RPC (cukup untuk development)
# Production: gunakan Alchemy/Infura/QuickNode untuk reliability
# Alchemy  → https://www.alchemy.com  (300M compute/month free)
# Infura   → https://infura.io
BASE_RPC_URL=https://mainnet.base.org

# ------------------------------------------
# APP CONFIG
# ------------------------------------------

# Rate limit per IP per menit
# Development: 10, Production: sesuaikan dengan traffic
RATE_LIMIT_MAX_PER_MINUTE=10

# URL aplikasi (dipakai untuk CORS & metadata)
# Development: http://localhost:3001
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3001
